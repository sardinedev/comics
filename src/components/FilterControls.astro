---
import Icon from "@components/Icon/Icon.astro";

type Props = {
  filterOptions: { publishers: string[]; years: string[] };
  showReadingState?: boolean;
};

const { filterOptions, showReadingState = true } = Astro.props;

const publisher = Astro.url.searchParams.get("publisher") ?? undefined;
const year = Astro.url.searchParams.get("year") ?? undefined;
const readingState = Astro.url.searchParams.get("state") ?? undefined;

const activeCount = [publisher, year, readingState].filter(Boolean).length;

function filterUrl(key: string, value: string | null) {
  const params = new URLSearchParams(Astro.url.searchParams);
  if (value) params.set(key, value);
  else params.delete(key);
  params.set("page", "1");
  return `?${params.toString()}`;
}
---

<button
  type="button"
  popovertarget="filter-popover"
  class:list={[
    "flex h-12 items-center gap-1.5 border bg-slate-800 px-3 text-xs font-bold uppercase tracking-widest transition-colors hover:border-amber-500 hover:text-amber-500",
    activeCount > 0 ? "border-amber-500 text-amber-500" : "border-slate-700 text-slate-300",
  ]}
>
  <Icon name="filter-list" class="h-3.5 w-3.5" color="currentColor" />
  Filter
  {activeCount > 0 && (
    <span class="flex h-4 w-4 items-center justify-center bg-amber-500 text-[9px] font-black text-slate-900">
      {activeCount}
    </span>
  )}
</button>

<div id="filter-popover" popover="manual" class="filter-popover" role="dialog">
  <div class="flex w-full flex-col border-t-2 border-amber-500 bg-slate-900 shadow-xl shadow-black/40">

    {showReadingState && (
      <div class="flex flex-col gap-3 border-b border-slate-800 p-4">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Reading State</span>
        <div class="flex flex-wrap gap-2">
          {(
            [["", "All"], ["unread", "Unread"], ["reading", "Reading"], ["read", "Read"]] as [string, string][]
          ).map(([val, label]) => {
            const active = (readingState ?? "") === val;
            return (
              <a
                href={filterUrl("state", val || null)}
                class:list={[
                  "px-3 py-1.5 text-xs font-bold uppercase tracking-widest border transition-colors",
                  active
                    ? "border-amber-500 bg-amber-500 text-slate-900"
                    : "border-slate-700 text-slate-400 hover:border-amber-500 hover:text-amber-500",
                ]}
              >
                {label}
              </a>
            );
          })}
        </div>
      </div>
    )}

    {filterOptions.publishers.length > 0 && (
      <div class="flex flex-col gap-3 border-b border-slate-800 p-4">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Publisher</span>
        <div class="flex flex-wrap gap-2">
          <a
            href={filterUrl("publisher", null)}
            class:list={[
              "px-3 py-1.5 text-xs font-bold uppercase tracking-widest border transition-colors",
              !publisher
                ? "border-amber-500 bg-amber-500 text-slate-900"
                : "border-slate-700 text-slate-400 hover:border-amber-500 hover:text-amber-500",
            ]}
          >
            All
          </a>
          {filterOptions.publishers.map((pub) => (
            <a
              href={filterUrl("publisher", pub)}
              class:list={[
                "px-3 py-1.5 text-xs font-bold uppercase tracking-widest border transition-colors",
                publisher === pub
                  ? "border-amber-500 bg-amber-500 text-slate-900"
                  : "border-slate-700 text-slate-400 hover:border-amber-500 hover:text-amber-500",
              ]}
            >
              {pub}
            </a>
          ))}
        </div>
      </div>
    )}

    {filterOptions.years.length > 0 && (
      <div class="flex flex-col gap-3 p-4">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Year</span>
        <div class="flex flex-wrap gap-2">
          <a
            href={filterUrl("year", null)}
            class:list={[
              "px-3 py-1.5 text-xs font-bold uppercase tracking-widest border transition-colors",
              !year
                ? "border-amber-500 bg-amber-500 text-slate-900"
                : "border-slate-700 text-slate-400 hover:border-amber-500 hover:text-amber-500",
            ]}
          >
            All
          </a>
          {filterOptions.years.map((y) => (
            <a
              href={filterUrl("year", y)}
              class:list={[
                "px-3 py-1.5 text-xs font-bold uppercase tracking-widest border transition-colors",
                year === y
                  ? "border-amber-500 bg-amber-500 text-slate-900"
                  : "border-slate-700 text-slate-400 hover:border-amber-500 hover:text-amber-500",
              ]}
            >
              {y}
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</div>

<style>
  .filter-popover {
    position: fixed;
    position-anchor: --util-anchor;
    position-area: bottom;
    width: 100vw;
    max-width: 1600px;
    left: 0;
    right: 0;
    margin-inline: auto;
    margin-top: 0.5rem;
  }
</style>
