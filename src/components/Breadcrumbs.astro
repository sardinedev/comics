---
type Crumb = {
  title: string;
  url?: string;
};

const { crumbs } = Astro.props as { crumbs: Crumb[] };
---

<nav class="mb-8 flex items-center gap-2 text-xs font-bold uppercase tracking-widest" aria-label="Breadcrumb">
  {
    crumbs.map((crumb, i) => (
      <>
        {i > 0 && <span class="text-slate-700">/</span>}
        {crumb.url ? (
          <a href={crumb.url} class="inline-flex items-center py-3 text-slate-500 hover:text-amber-500 transition-colors">
            {crumb.title}
          </a>
        ) : (
          <span class="text-slate-400">{crumb.title}</span>
        )}
      </>
    ))
  }
</nav>
