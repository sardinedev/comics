---
import Icon from "@components/Icon/Icon.astro";
---

<header class="sticky top-0 z-40 border-b border-slate-800 bg-slate-900/95 backdrop-blur-sm">
  <div class="mx-auto flex w-full max-w-[1600px] items-center justify-between px-4 py-3">
  <a href="/" class="flex items-center gap-3">
    <img height="19" width="100" src="/logo.svg" alt="Logo" class="logo" />
  </a>

  <nav class="hidden items-center gap-6 sm:flex">
    <a href="/series" class="text-xs font-bold uppercase tracking-widest text-slate-400 transition-colors hover:text-amber-500">Series</a>
    <a href="/new" class="text-xs font-bold uppercase tracking-widest text-slate-400 transition-colors hover:text-amber-500">New</a>
  </nav>

  <div class="flex items-center gap-2">
    <button
      id="header-search-btn"
      aria-label="Search"
      class="flex items-center gap-2 rounded-none border border-slate-700 bg-slate-800 px-3 py-1.5 text-xs text-slate-400 transition-colors hover:border-amber-500 hover:text-amber-500"
    >
      <Icon name="search" class="h-3.5 w-3.5" color="currentColor" />
      <span class="hidden sm:inline">Search</span>
      <kbd class="hidden rounded bg-slate-700 px-1 py-0.5 text-[10px] font-mono text-slate-500 sm:inline">⌘K</kbd>
    </button>
    <form method="POST" action="/api/auth/logout">
      <button
        type="submit"
        aria-label="Sign out"
        class="flex items-center gap-1.5 rounded-none border border-slate-700 bg-slate-800 px-3 py-1.5 text-xs text-slate-400 transition-colors hover:border-slate-600 hover:text-slate-300"
      >
        <Icon name="logout" class="h-3.5 w-3.5" color="currentColor" />
        <span class="hidden sm:inline">Sign out</span>
      </button>
    </form>
  </div>
  </div>
</header>

<script>
  const btn = document.getElementById("header-search-btn");
  btn?.addEventListener("click", () => {
    const overlay = document.getElementById("search-overlay");
    overlay?.classList.remove("hidden");
    overlay?.classList.add("flex");
    overlay?.querySelector("input")?.focus();
  });
</script>
