---
import Layout from "@layouts/Layout.astro";
import { getIssue } from "@data/elastic/queries";
import { Image } from "astro:assets";
import Icon from "@components/Icon/Icon.astro";
import SubHeading from "@components/SubHeading.astro";
import EyebrowLabel from "@components/EyebrowLabel.astro";
import PageHeading from "@components/PageHeading.astro";
import { thumbHashToBase64 } from "@util/thumbHashToBase64";

const { id } = Astro.params;
const issue = await getIssue(id!);

if (!issue) return Astro.redirect("/series");

const pct =
  issue.current_page && issue.issue_page_count
    ? Math.round((issue.current_page / issue.issue_page_count) * 100)
    : null;

const creators: { label: string; names: string[] }[] = [
  { label: "Writer", names: issue.writers ?? [] },
  { label: "Artist", names: issue.artists ?? [] },
  { label: "Colorist", names: issue.colorists ?? [] },
  { label: "Letterer", names: issue.letterers ?? [] },
  { label: "Cover", names: issue.cover_artists ?? [] },
  { label: "Editor", names: issue.editors ?? [] },
].filter((c) => c.names.length > 0);

const statusColors: Record<string, string> = {
  reading: "bg-amber-500 text-slate-900",
  read: "bg-slate-700 text-slate-300",
  unread: "bg-slate-800 text-slate-400",
};
const statusColor =
  statusColors[issue.reading_state ?? "unread"] ?? statusColors.unread;

let heroPlaceholderUrl: string | undefined;
if (issue.issue_cover_thumb_hash) {
  heroPlaceholderUrl = await thumbHashToBase64(issue.issue_cover_thumb_hash);
}
---

<Layout title={`${issue.series_name} #${issue.issue_number}`}>
  <!-- Breadcrumb -->
  <nav
    class="mb-8 flex items-center gap-2 text-xs font-bold uppercase tracking-widest"
  >
    <a
      href="/series"
      class="text-slate-500 hover:text-amber-500 transition-colors">Series</a
    >
    <span class="text-slate-700">/</span>
    <a
      href={`/series/${issue.series_id}`}
      class="text-slate-500 hover:text-amber-500 transition-colors"
      >{issue.series_name}</a
    >
    <span class="text-slate-700">/</span>
    <span class="text-slate-400">#{issue.issue_number}</span>
  </nav>

  <style>
    /*
      Mobile:  1-col grid
               title(1) → reading-state(2) → cover(3) → meta(4) → desc(5) → creators(6) → file(7)
      Tablet + Desktop (768px+): 2-col [240px 1fr]
               left:  cover(r1), meta(r2)
               right: title+reading-state-inline(r1), desc(r2), creators(r3), file(r4)
               .issue-reading (standalone) hidden; .issue-reading-inline shown inside title
    */
    .issue-layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .issue-title {
      grid-row: 1;
    }
    .issue-reading {
      grid-row: 2;
    }
    .issue-cover {
      grid-row: 3;
    }
    .issue-meta {
      grid-row: 4;
    }
    .issue-desc {
      grid-row: 5;
    }
    .issue-creators {
      grid-row: 6;
    }
    .issue-file {
      grid-row: 7;
    }
    .issue-reading-inline {
      display: none;
    }

    @media (min-width: 768px) {
      .issue-layout {
        grid-template-columns: 240px 1fr;
        align-items: start;
        gap: 2.5rem;
      }
      .issue-title {
        grid-column: 2;
        grid-row: 1;
      }
      .issue-reading {
        display: none;
      }
      .issue-reading-inline {
        display: flex;
      }
      .issue-cover {
        grid-column: 1;
        grid-row: 1;
      }
      .issue-meta {
        grid-column: 1;
        grid-row: 2;
      }
      .issue-desc {
        grid-column: 2;
        grid-row: 2;
      }
      .issue-creators {
        grid-column: 2;
        grid-row: 3;
      }
      .issue-file {
        grid-column: 2;
        grid-row: 4;
      }
    }
  </style>

  <div class="issue-layout">
    <!-- Title -->
    <div class="issue-title flex flex-col gap-3">
      <EyebrowLabel>{issue.series_name} · {issue.series_year}</EyebrowLabel>
      <PageHeading>
        {
          issue.issue_name ? (
            <>
              {issue.issue_name}
              <span class="ml-3 text-2xl font-bold text-slate-600">
                #{issue.issue_number}
              </span>
            </>
          ) : (
            <>
              Issue <span class="text-amber-500">#{issue.issue_number}</span>
            </>
          )
        }
      </PageHeading>
      <!-- Reading state inline — tablet only (shown via CSS, hidden on mobile/desktop) -->
      <div class={`issue-reading-inline flex-col gap-2`}>
        <span
          class={`self-start px-2 py-1 text-[10px] font-black uppercase tracking-widest ${statusColor}`}
        >
          {issue.reading_state ?? "Unread"}
        </span>
        {
          pct !== null && (
            <div class="flex flex-col gap-1">
              <div class="flex justify-between text-xs text-slate-600">
                <span class="uppercase tracking-widest">Progress</span>
                <span class="font-semibold text-amber-500">{pct}%</span>
              </div>
              <div class="h-1 overflow-hidden bg-slate-800">
                <div class="h-full bg-amber-500" style={`width: ${pct}%`} />
              </div>
              <p class="text-xs text-slate-600">
                Page {issue.current_page} of {issue.issue_page_count}
              </p>
            </div>
          )
        }
      </div>
    </div>

    <!-- Reading state — mobile + desktop only (hidden on tablet via CSS) -->
    <div class={`issue-reading flex flex-col gap-2`}>
      <span
        class={`self-start px-2 py-1 text-[10px] font-black uppercase tracking-widest ${statusColor}`}
      >
        {issue.reading_state ?? "Unread"}
      </span>
      {
        pct !== null && (
          <div class="flex flex-col gap-1">
            <div class="flex justify-between text-xs text-slate-600">
              <span class="uppercase tracking-widest">Progress</span>
              <span class="font-semibold text-amber-500">{pct}%</span>
            </div>
            <div class="h-1 overflow-hidden bg-slate-800">
              <div class="h-full bg-amber-500" style={`width: ${pct}%`} />
            </div>
            <p class="text-xs text-slate-600">
              Page {issue.current_page} of {issue.issue_page_count}
            </p>
          </div>
        )
      }
    </div>

    <!-- Cover -->
    <div
      class="issue-cover relative overflow-hidden h-[360px] w-[240px] mx-auto"
    >
      {
        issue.issue_cover_url ? (
          <div
            class="absolute inset-0 overflow-hidden rounded-sm shadow-2xl ring-1 ring-white/10"
            style={
              heroPlaceholderUrl
                ? `background-image: url(${heroPlaceholderUrl}); background-size: cover; background-position: center;`
                : undefined
            }
          >
            <Image
              src={new URL(issue.issue_cover_url, Astro.url).toString()}
              alt={`${issue.series_name} #${issue.issue_number}`}
              widths={[240, 343, 480, 686]}
              sizes="(max-width: 767px) 343px, 240px"
              width={240}
              height={360}
              quality="mid"
              format="avif"
              class="aspect-[2/3] w-full object-cover"
            />
          </div>
        ) : (
          <div class="aspect-[2/3] flex items-center justify-center bg-gradient-to-br from-slate-700 to-slate-800">
            <Icon
              name="image-placeholder"
              class="h-16 w-16"
              color="rgb(71 85 105)"
            />
          </div>
        )
      }
    </div>

    <!-- Quick meta -->
    <dl class="issue-meta flex flex-col gap-2 border-t border-slate-800 pt-4">
      {
        issue.issue_date && (
          <div class="flex justify-between">
            <dt class="text-xs uppercase tracking-widest text-slate-600">
              Released
            </dt>
            <dd class="text-xs font-semibold text-slate-300">
              {issue.issue_date.slice(0, 10)}
            </dd>
          </div>
        )
      }
      {
        issue.issue_page_count && (
          <div class="flex justify-between">
            <dt class="text-xs uppercase tracking-widest text-slate-600">
              Pages
            </dt>
            <dd class="text-xs font-semibold text-slate-300">
              {issue.issue_page_count}
            </dd>
          </div>
        )
      }
      {
        issue.series_publisher && (
          <div class="flex justify-between">
            <dt class="text-xs uppercase tracking-widest text-slate-600">
              Publisher
            </dt>
            <dd class="text-xs font-semibold text-slate-300">
              {issue.series_publisher}
            </dd>
          </div>
        )
      }
    </dl>

    <!-- Description -->
    {
      issue.issue_description && (
        <div class="issue-desc flex flex-col gap-2">
          <SubHeading>Synopsis</SubHeading>
          <div
            class="max-w-2xl text-sm leading-relaxed text-slate-300"
            set:html={issue.issue_description}
          />
        </div>
      )
    }

    <!-- Creators -->
    {
      creators.length > 0 && (
        <div class="issue-creators flex flex-col gap-4">
          <SubHeading>Creators</SubHeading>
          <dl class="grid grid-cols-2 gap-x-8 gap-y-3 sm:grid-cols-3">
            {creators.map(({ label, names }) => (
              <div class="flex flex-col gap-1">
                <dt class="text-[10px] font-bold uppercase tracking-widest text-slate-600">
                  {label}
                </dt>
                {names.map((name) => (
                  <dd class="text-sm text-slate-300">{name}</dd>
                ))}
              </div>
            ))}
          </dl>
        </div>
      )
    }

    <!-- File info -->
    {
      issue.mylar_file_location && (
        <div class="issue-file flex flex-col gap-2 border-t border-slate-800 pt-6">
          <SubHeading>File</SubHeading>
          <p class="font-mono text-xs text-slate-500 break-all">
            {issue.mylar_file_location}
          </p>
        </div>
      )
    }
  </div>
</Layout>
