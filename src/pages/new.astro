---
import Layout from "@layouts/Layout.astro";
import { getNewlyAddedIssues } from "@data/elastic/queries";
import { getWeeklyComics } from "@data/comicvine/comicvine";
import { Image } from "astro:assets";
import CoverLeaf from "@components/CoverLeaf/CoverLeaf.astro";

const now = new Date();
const dayOfWeek = now.getDay();
const daysFromMonday = (dayOfWeek + 6) % 7;
const monday = new Date(now);
monday.setDate(now.getDate() - daysFromMonday);
monday.setHours(0, 0, 0, 0);

const sunday = new Date(monday);
sunday.setDate(monday.getDate() + 6);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
const weekLabel = monday.toLocaleDateString("en-US", { month: "short", day: "numeric" })
  + " – "
  + sunday.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

const [addedIssues, weeklyComics] = await Promise.all([
  getNewlyAddedIssues(),
  getWeeklyComics(fmt(monday), fmt(sunday)),
]);
---

<Layout title="New this week">
  <div class="mb-10 border-b border-slate-800 pb-6">
    <p class="mb-1 text-xs font-bold uppercase tracking-[0.3em] text-amber-500">Week of {weekLabel}</p>
    <h1 class="text-4xl font-black tracking-tight text-white">New This Week</h1>
  </div>

  <!-- Recently added to library -->
  <section class="mb-16">
    <div class="mb-6 flex items-end justify-between">
      <div>
        <p class="mb-1 text-xs font-bold uppercase tracking-[0.3em] text-amber-500">In your collection</p>
        <h2 class="text-2xl font-black tracking-tight text-white">Recently Added</h2>
      </div>
      <span class="text-xs font-bold uppercase tracking-widest text-slate-500">{addedIssues.length} issue{addedIssues.length !== 1 ? "s" : ""}</span>
    </div>

    {addedIssues.length === 0 ? (
      <p class="text-sm text-slate-600">Nothing added yet.</p>
    ) : (
      <ol class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6">
        {addedIssues.map((issue) => (
          <CoverLeaf
            type="Issue"
            id={issue.issue_id}
            cover={issue.issue_cover_url}
            number={issue.issue_number}
            seriesName={issue.series_name}
            seriesId={issue.series_id}
            badge="new"
          />
        ))}
      </ol>
    )}
  </section>

  <!-- Published this week via ComicVine -->
  <section class="mb-12">
    <div class="mb-6 flex items-end justify-between">
      <div>
        <p class="mb-1 text-xs font-bold uppercase tracking-[0.3em] text-amber-500">Store date {weekLabel}</p>
        <h2 class="text-2xl font-black tracking-tight text-white">Published This Week</h2>
      </div>
      <span class="text-xs font-bold uppercase tracking-widest text-slate-500">{weeklyComics.totalResults} issue{weeklyComics.totalResults !== 1 ? "s" : ""}</span>
    </div>

    {weeklyComics.issues.length === 0 ? (
      <p class="text-sm text-slate-600">No issues this week.</p>
    ) : (
      <ol class="grid grid-cols-1 gap-px bg-slate-800 sm:grid-cols-2 lg:grid-cols-3">
        {weeklyComics.issues.map((issue) => (
          <li class="bg-slate-900">
            <a href={`/series/${issue.volume.id}`} class="group flex items-center gap-4 p-4 transition-colors hover:bg-slate-800">
              <div class="relative aspect-[2/3] w-14 shrink-0 overflow-hidden rounded-sm ring-1 ring-white/5 transition-all group-hover:ring-amber-500/30">
                <Image
                  src={issue.image.small_url}
                  alt={`${issue.volume.name} #${issue.issue_number}`}
                  width={56}
                  height={84}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="flex flex-1 flex-col gap-1 overflow-hidden">
                <span class="truncate text-base font-bold text-white transition-colors group-hover:text-amber-400">{issue.volume.name}</span>
                <span class="text-xs text-slate-500">
                  #{issue.issue_number}{issue.name ? ` — ${issue.name}` : ""}
                </span>
                {issue.store_date && (
                  <span class="text-xs text-slate-600">{issue.store_date}</span>
                )}
              </div>
              <svg class="h-4 w-4 shrink-0 text-slate-700 transition-all group-hover:translate-x-1 group-hover:text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </li>
        ))}
      </ol>
    )}
  </section>
</Layout>
