---
import Layout from "@layouts/Layout.astro";
import { getSeriesIssues } from "@data/elastic/queries";
import { getVolumeDetails, getIssuesFromVolume } from "@data/comicvine/comicvine";
import type { ComicvineVolume } from "@data/comicvine/comicvine.types";
import { Image } from "astro:assets";
import PageNavigator from "@components/PageNavigator.astro";

const { id } = Astro.params;
const currentPage = parseInt(Astro.url.searchParams.get("page") || "1", 10);
const { series, items: issues, totalPages, total } = await getSeriesIssues(id!, currentPage);

const CV_PAGE_SIZE = 18;

let cvVolume: ComicvineVolume | null = null;
let cvPageIssues: Awaited<ReturnType<typeof getIssuesFromVolume>> = [];
let cvTotalPages = 0;

if (!series) {
  try {
    cvVolume = await getVolumeDetails(id!);
  } catch {
    cvVolume = null;
  }
  if (!cvVolume) return Astro.redirect("/series");

  const offset = (currentPage - 1) * CV_PAGE_SIZE;
  cvPageIssues = (await getIssuesFromVolume(id!, offset))?.slice(0, CV_PAGE_SIZE) ?? [];
  cvTotalPages = Math.ceil((cvVolume.count_of_issues ?? 0) / CV_PAGE_SIZE);
}

// Normalise to a common shape for the template
const name        = series?.series_name        ?? cvVolume!.name;
const year        = series?.series_year        ?? cvVolume!.start_year;
const publisher   = series?.series_publisher   ?? cvVolume!.publisher?.name;
const totalIssues = series?.series_total_issues ?? cvVolume!.count_of_issues;

const readCount   = issues.filter((i) => i.reading_state === "read").length;
const readingCount = issues.filter((i) => i.reading_state === "reading").length;
const readPct     = total ? Math.round((readCount / total) * 100) : 0;

// Cover images for the stack
const cover1 = issues[0]?.issue_cover_url ?? cvVolume?.image?.medium_url ?? null;
const cover2 = issues[1]?.issue_cover_url ?? null;

---

<Layout title={name}>
  <!-- Series header -->
  <div class="relative -mx-4 -mt-4 mb-10 border-b border-slate-800">
    <div class="flex flex-col gap-8 px-4 py-10 md:flex-row md:items-end md:px-8">

      <!-- Cover stack -->
      <div class="relative h-[240px] w-[180px] shrink-0 self-center md:self-auto">
        <!-- Issue #2 / fallback behind -->
        {cover2 ? (
          <div class="absolute left-6 top-3 h-[220px] w-[148px] rotate-6 overflow-hidden rounded-sm shadow-xl ring-1 ring-white/10">
            <Image src={cover2} alt={`${name} #2`} width={148} height={220} class="h-full w-full object-cover" />
          </div>
        ) : (
          <div class="absolute left-6 top-3 h-[220px] w-[148px] rotate-6 rounded-sm bg-slate-700 opacity-50 shadow-xl"></div>
        )}
        <!-- Issue #1 / series cover in front -->
        <div class="absolute inset-y-0 left-0 w-[148px] overflow-hidden rounded-sm shadow-2xl ring-1 ring-white/10">
          {cover1 ? (
            <Image src={cover1} alt={name} width={148} height={220} class="h-full w-full object-cover" />
          ) : (
            <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-700 to-slate-800">
              <svg class="h-12 w-12 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
          )}
        </div>
      </div>

      <!-- Meta -->
      <div class="flex flex-1 flex-col gap-4">
        <div class="flex items-center gap-3">
          <a href="/series" class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-amber-500 transition-colors">Series</a>
          <span class="text-slate-700">/</span>
          <span class="text-xs font-bold uppercase tracking-widest text-slate-400">{name}</span>
        </div>
        <h1 class="text-4xl font-black leading-tight tracking-tight text-white md:text-5xl">{name}</h1>
        <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400">
          {publisher && <a href={`/series?publisher=${encodeURIComponent(publisher)}&page=1`} class="hover:text-amber-500 transition-colors">{publisher}</a>}
          {year && <><span class="text-slate-700">·</span><a href={`/series?year=${year}&page=1`} class="hover:text-amber-500 transition-colors">{year}</a></>}
          {totalIssues && <><span class="text-slate-700">·</span><span>{totalIssues} issues</span></>}
          {readingCount > 0 && <><span class="text-slate-700">·</span><span class="text-amber-500">{readingCount} in progress</span></>}
          {cvVolume && <><span class="text-slate-700">·</span><span class="text-xs font-bold uppercase tracking-widest text-slate-600">Not in library</span></>}
        </div>

        {cvVolume && (
          <div class="flex items-center gap-3">
            <button
              id="add-to-library-btn"
              data-series-id={id}
              class="group flex items-center gap-2 bg-amber-500 px-5 py-2.5 text-sm font-bold uppercase tracking-widest text-slate-900 transition-all hover:bg-amber-400 disabled:cursor-not-allowed disabled:opacity-50"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              Add to library
            </button>
            <span id="add-to-library-status" class="hidden text-xs font-bold uppercase tracking-widest"></span>
          </div>
        )}
        </div>

        {readCount > 0 && (
          <div class="flex max-w-sm flex-col gap-1.5">
            <div class="flex justify-between text-xs text-slate-600">
              <span class="uppercase tracking-widest">Read</span>
              <span class="font-semibold text-amber-500">{readCount} / {total}</span>
            </div>
            <div class="h-1 w-full overflow-hidden bg-slate-800">
              <div class="h-full bg-amber-500" style={`width: ${readPct}%`}></div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

<script>
  const btn = document.getElementById("add-to-library-btn") as HTMLButtonElement | null;
  const status = document.getElementById("add-to-library-status");

  btn?.addEventListener("click", async () => {
    const seriesId = btn.dataset.seriesId;
    btn.disabled = true;
    btn.textContent = "Adding…";

    try {
      const res = await fetch("/api/library/add", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ seriesId }),
      });

      if (res.ok) {
        btn.classList.add("hidden");
        if (status) {
          status.textContent = "Added to library";
          status.classList.remove("hidden");
          status.classList.add("text-amber-500");
        }
      } else {
        btn.disabled = false;
        btn.innerHTML = `<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Add to library`;
        if (status) {
          status.textContent = "Failed — try again";
          status.classList.remove("hidden");
          status.classList.add("text-red-400");
        }
      }
    } catch {
      btn.disabled = false;
      btn.innerHTML = `<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Add to library`;
    }
  });
</script>

  <!-- Elastic: full issue grid with reading state -->
  {issues.length > 0 && (
    <ol class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6">
      {issues.map((issue) => {
        const pct = issue.current_page && issue.issue_page_count
          ? Math.round((issue.current_page / issue.issue_page_count) * 100)
          : null;
        return (
          <li class="group flex flex-col gap-2">
            <a href={`/comic/${issue.issue_id}`} class="relative block overflow-hidden rounded-sm ring-1 ring-white/5 transition-all duration-200 hover:ring-amber-500/40 hover:shadow-lg hover:shadow-amber-500/10">
              {issue.issue_cover_url ? (
                <Image src={issue.issue_cover_url} alt={`${name} #${issue.issue_number}`} width={210} height={320} class="aspect-[2/3] w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" loading="lazy" />
              ) : (
                <div class="aspect-[2/3] flex items-center justify-center bg-gradient-to-br from-slate-700 via-slate-800 to-slate-900">
                  <svg class="h-8 w-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
              )}
              {issue.reading_state === "read" && (
                <span class="absolute right-2 top-2 bg-slate-900/80 px-1.5 py-0.5 text-[9px] font-black uppercase tracking-widest text-slate-400 backdrop-blur-sm">Read</span>
              )}
              {issue.reading_state === "reading" && (
                <span class="absolute right-2 top-2 bg-amber-500 px-1.5 py-0.5 text-[9px] font-black uppercase tracking-widest text-slate-900">Reading</span>
              )}
              {pct !== null && (
                <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-slate-800">
                  <div class="h-full bg-amber-500" style={`width: ${pct}%`}></div>
                </div>
              )}
            </a>
            <div class="flex flex-col gap-0.5 px-0.5">
              <span class="text-sm font-bold text-white">#{issue.issue_number}</span>
              {issue.issue_name && <span class="truncate text-xs text-slate-500">{issue.issue_name}</span>}
              {issue.issue_date && <span class="text-xs text-slate-600">{issue.issue_date.slice(0, 7)}</span>}
            </div>
          </li>
        );
      })}
    </ol>
  )}

  <!-- ComicVine fallback: same issue grid with real covers -->
  {cvVolume && cvPageIssues && cvPageIssues.length > 0 && (
    <ol class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6">
      {cvPageIssues.map((issue) => (
        <li class="group flex flex-col gap-2">
          <a href={`/comic/${issue.id}`} class="relative block overflow-hidden rounded-sm ring-1 ring-white/5 transition-all duration-200 hover:ring-amber-500/40 hover:shadow-lg hover:shadow-amber-500/10">
            {issue.image?.medium_url ? (
              <Image
                src={issue.image.medium_url}
                alt={`${name} #${issue.issue_number}`}
                width={210}
                height={320}
                class="aspect-[2/3] w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                loading="lazy"
              />
            ) : (
              <div class="aspect-[2/3] flex items-center justify-center bg-gradient-to-br from-slate-700 via-slate-800 to-slate-900">
                <svg class="h-8 w-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
            )}
          </a>
          <div class="flex flex-col gap-0.5 px-0.5">
            <span class="text-sm font-bold text-white">#{issue.issue_number}</span>
            {issue.name && <span class="truncate text-xs text-slate-500">{issue.name}</span>}
            {issue.cover_date && <span class="text-xs text-slate-600">{issue.cover_date.slice(0, 7)}</span>}
          </div>
        </li>
      ))}
    </ol>
  )}

  {issues.length > 0 && <PageNavigator numberOfPages={totalPages} currentPage={currentPage} />}
  {cvVolume && cvTotalPages > 1 && <PageNavigator numberOfPages={cvTotalPages} currentPage={currentPage} />}
</Layout>
