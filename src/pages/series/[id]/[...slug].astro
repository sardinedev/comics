---
import Layout from "@layouts/Layout.astro";
import { getSeriesIssues } from "@data/elastic/queries";
import { Image } from "astro:assets";
import PageNavigator from "@components/PageNavigator.astro";

const { id } = Astro.params;
const currentPage = parseInt(Astro.url.searchParams.get("page") || "1", 10);
const { series, items: issues, totalPages, total } = await getSeriesIssues(id!, currentPage);

if (!series) return Astro.redirect("/series");

const readCount = issues.filter((i) => i.reading_state === "read").length;
const readingCount = issues.filter((i) => i.reading_state === "reading").length;
const readPct = total ? Math.round((readCount / total) * 100) : 0;
---

<Layout title={series.series_name}>
  <!-- Series header -->
  <div class="relative -mx-4 -mt-4 mb-10 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950"></div>
    <div class="absolute -right-24 top-0 h-[400px] w-[400px] rounded-full bg-amber-500/10 blur-[100px]"></div>

    <div class="relative z-10 flex flex-col gap-8 px-4 py-10 md:flex-row md:items-end md:px-8">
      <!-- Cover stack (first two issues) -->
      <div class="relative h-[240px] w-[180px] shrink-0 self-center md:self-auto">
        <!-- Issue #2 behind -->
        {issues[1]?.issue_cover_url ? (
          <div class="absolute left-6 top-3 h-[220px] w-[148px] rotate-6 overflow-hidden rounded-sm shadow-xl ring-1 ring-white/10">
            <Image
              src={issues[1].issue_cover_url}
              alt={`${series.series_name} #${issues[1].issue_number}`}
              width={148}
              height={220}
              class="h-full w-full object-cover"
            />
          </div>
        ) : (
          <div class="absolute left-6 top-3 h-[220px] w-[148px] rotate-6 rounded-sm bg-slate-700 opacity-50 shadow-xl"></div>
        )}
        <!-- Issue #1 in front -->
        <div class="absolute inset-y-0 left-0 w-[148px] overflow-hidden rounded-sm shadow-2xl ring-1 ring-white/10">
          {issues[0]?.issue_cover_url ? (
            <Image
              src={issues[0].issue_cover_url}
              alt={`${series.series_name} #${issues[0].issue_number}`}
              width={148}
              height={220}
              class="h-full w-full object-cover"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-700 to-slate-800">
              <svg class="h-12 w-12 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
          )}
        </div>
      </div>

      <!-- Meta -->
      <div class="flex flex-1 flex-col gap-4">
        <div class="flex items-center gap-3">
          <a href="/series" class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-amber-500 transition-colors">Series</a>
          <span class="text-slate-700">/</span>
          <span class="text-xs font-bold uppercase tracking-widest text-slate-400">{series.series_name}</span>
        </div>
        <h1 class="text-4xl font-black leading-tight tracking-tight text-white md:text-5xl">
          {series.series_name}
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400">
          {series.series_publisher && <span>{series.series_publisher}</span>}
          {series.series_year && <><span class="text-slate-700">·</span><span>{series.series_year}</span></>}
          <span class="text-slate-700">·</span>
          <span>{issues.length} issues</span>
          {readingCount > 0 && (
            <><span class="text-slate-700">·</span><span class="text-amber-500">{readingCount} in progress</span></>
          )}
        </div>

        <!-- Progress bar -->
        {readCount > 0 && (
          <div class="flex max-w-sm flex-col gap-1.5">
            <div class="flex justify-between text-xs text-slate-600">
              <span class="uppercase tracking-widest">Read</span>
              <span class="font-semibold text-amber-500">{readCount} / {issues.length}</span>
            </div>
            <div class="h-1 w-full overflow-hidden bg-slate-800">
              <div class="h-full bg-amber-500" style={`width: ${readPct}%`}></div>
            </div>
          </div>
        )}
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-10 bg-gradient-to-t from-slate-900 to-transparent"></div>
  </div>

  <!-- Issue list -->
  <ol class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6">
    {issues.map((issue) => {
      const pct = issue.current_page && issue.issue_page_count
        ? Math.round((issue.current_page / issue.issue_page_count) * 100)
        : null;

      return (
        <li class="group flex flex-col gap-2">
          <a
            href={`/comic/${issue.issue_id}`}
            class="relative block overflow-hidden rounded-sm ring-1 ring-white/5 transition-all duration-200 hover:ring-amber-500/40 hover:shadow-lg hover:shadow-amber-500/10"
          >
            {issue.issue_cover_url ? (
              <Image
                src={issue.issue_cover_url}
                alt={`${series.series_name} #${issue.issue_number}`}
                width={210}
                height={320}
                class="aspect-[2/3] w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                loading="lazy"
              />
            ) : (
              <div class="aspect-[2/3] flex items-center justify-center bg-gradient-to-br from-slate-700 via-slate-800 to-slate-900">
                <svg class="h-8 w-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
            )}

            <!-- Reading state badge -->
            {issue.reading_state === "read" && (
              <span class="absolute right-2 top-2 bg-slate-900/80 px-1.5 py-0.5 text-[9px] font-black uppercase tracking-widest text-slate-400 backdrop-blur-sm">Read</span>
            )}
            {issue.reading_state === "reading" && (
              <span class="absolute right-2 top-2 bg-amber-500 px-1.5 py-0.5 text-[9px] font-black uppercase tracking-widest text-slate-900">Reading</span>
            )}

            <!-- Progress bar -->
            {pct !== null && (
              <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-slate-800">
                <div class="h-full bg-amber-500" style={`width: ${pct}%`}></div>
              </div>
            )}
          </a>

          <div class="flex flex-col gap-0.5 px-0.5">
            <span class="text-sm font-bold text-white">#{issue.issue_number}</span>
            {issue.issue_name && (
              <span class="truncate text-xs text-slate-500">{issue.issue_name}</span>
            )}
            {issue.issue_date && (
              <span class="text-xs text-slate-600">{issue.issue_date.slice(0, 7)}</span>
            )}
          </div>
        </li>
      );
    })}
  </ol>

  <PageNavigator numberOfPages={totalPages} currentPage={currentPage} />
</Layout>
