---
import Layout from "@layouts/Layout.astro";
import { getSeriesIssues } from "@data/elastic/queries";
import {
  getVolumeDetails,
  getIssuesFromVolume,
} from "@data/comicvine/comicvine";
import type { ComicvineVolume } from "@data/comicvine/comicvine.types";
import { Image } from "astro:assets";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import PageNavigator from "@components/PageNavigator.astro";
import CoverLeaf from "@components/CoverLeaf/CoverLeaf.astro";
import Icon from "@components/Icon/Icon.astro";
import PageHeading from "@components/PageHeading.astro";
import CoverGrid from "@components/CoverGrid.astro";

const { id } = Astro.params;
const currentPage = parseInt(Astro.url.searchParams.get("page") || "1", 10);
const CV_PAGE_SIZE = 24;
const {
  series,
  items: issues,
  totalPages,
  total,
} = await getSeriesIssues(id!, currentPage, CV_PAGE_SIZE);

let cvVolume: ComicvineVolume | null = null;
let cvPageIssues: Awaited<ReturnType<typeof getIssuesFromVolume>> = [];
let cvTotalPages = 0;

if (!series) {
  try {
    cvVolume = await getVolumeDetails(id!);
  } catch {
    cvVolume = null;
  }
  if (!cvVolume) return Astro.redirect("/series");

  const offset = (currentPage - 1) * CV_PAGE_SIZE;
  cvPageIssues =
    (await getIssuesFromVolume(id!, offset))?.slice(0, CV_PAGE_SIZE) ?? [];
  cvTotalPages = Math.ceil((cvVolume.count_of_issues ?? 0) / CV_PAGE_SIZE);
}

// Normalise to a common shape for the template
const name = series?.series_name ?? cvVolume!.name;
const year = series?.series_year ?? cvVolume!.start_year;
const publisher = series?.series_publisher ?? cvVolume!.publisher?.name;
const totalIssues = series?.series_total_issues ?? cvVolume!.count_of_issues;

const readCount = issues.filter((i) => i.reading_state === "read").length;
const readingCount = issues.filter((i) => i.reading_state === "reading").length;
const readPct = total ? Math.round((readCount / total) * 100) : 0;

// Cover images for the stack
const cover1 =
  issues[0]?.issue_cover_url ?? cvVolume?.image?.medium_url ?? null;
const cover2 = issues[1]?.issue_cover_url ?? null;
---

<Layout title={name}>
  <Breadcrumbs
    crumbs={[
      { title: "Series", url: "/series" },
      { title: name, url: `/series/${id}` },
    ]}
  />
  <!-- Series header -->
  <div class="relative -mx-4 -mt-4 mb-10 border-b border-slate-800">
    <div
      class="flex flex-col gap-8 px-4 py-10 md:flex-row md:items-end md:px-8"
    >
      <!-- Cover stack -->
      <div
        class="relative h-[240px] w-[180px] shrink-0 self-center md:self-auto"
      >
        <!-- Issue #2 / fallback behind -->
        {
          cover2 ? (
            <div class="absolute left-6 top-3 h-[220px] w-[148px] rotate-6 overflow-hidden rounded-sm shadow-xl ring-1 ring-white/10">
              <Image
                src={new URL(cover2!, Astro.url).toString()}
                alt={`${name} #2`}
                widths={[183, 275, 366]}
                sizes="(max-width: 640px) 183px, 210px"
                width={210}
                height={320}
                quality="mid"
                format="avif"
                width={148}
                height={220}
                class="h-full w-full object-cover"
              />
            </div>
          ) : (
            <div class="absolute left-6 top-3 h-[220px] w-[148px] rotate-6 rounded-sm bg-slate-700 opacity-50 shadow-xl" />
          )
        }
        <!-- Issue #1 / series cover in front -->
        <div
          class="absolute inset-y-0 left-0 w-[148px] overflow-hidden rounded-sm shadow-2xl ring-1 ring-white/10"
        >
          {
            cover1 ? (
              <Image
                src={new URL(cover1!, Astro.url).toString()}
                alt={`${name} #2`}
                widths={[183, 275, 366]}
                sizes="(max-width: 640px) 183px, 210px"
                width={210}
                height={320}
                quality="mid"
                format="avif"
                width={148}
                height={220}
                class="h-full w-full object-cover"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-700 to-slate-800">
                <Icon
                  name="image-placeholder"
                  class="h-12 w-12"
                  color="rgb(71 85 105)"
                />
              </div>
            )
          }
        </div>
      </div>

      <!-- Meta -->
      <div class="flex flex-1 flex-col gap-1">
        <PageHeading>{name}</PageHeading>
        <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400">
          {
            publisher && (
              <a
                href={`/series?publisher=${encodeURIComponent(publisher)}&page=1`}
                class="hover:text-amber-500 transition-colors"
              >
                {publisher}
              </a>
            )
          }
          {
            year && (
              <>
                <>
                  <span class="text-slate-700">·</span>
                  <a
                    href={`/series?year=${year}&page=1`}
                    class="hover:text-amber-500 transition-colors"
                  >
                    {year}
                  </a>
                </>
              </>
            )
          }
          {
            totalIssues && (
              <>
                <>
                  <span class="text-slate-700">·</span>
                  <span>{totalIssues} issues</span>
                </>
              </>
            )
          }
          {
            readingCount > 0 && (
              <>
                <>
                  <span class="text-slate-700">·</span>
                  <span class="text-amber-500">{readingCount} in progress</span>
                </>
              </>
            )
          }
          {
            cvVolume && (
              <>
                <>
                  <span class="text-slate-700">·</span>
                  <span class="text-xs font-bold uppercase tracking-widest text-slate-600">
                    Not in library
                  </span>
                </>
              </>
            )
          }
        </div>

        {
          cvVolume && (
            <div class="flex items-center gap-3">
              <button
                id="add-to-library-btn"
                data-series-id={id}
                class="group flex items-center gap-2 bg-amber-500 px-5 py-2.5 text-sm font-bold uppercase tracking-widest text-slate-900 transition-all hover:bg-amber-400 disabled:cursor-not-allowed disabled:opacity-50"
              >
                <Icon name="add" class="h-4 w-4" color="currentColor" />
                Add to library
              </button>
              <span
                id="add-to-library-status"
                class="hidden text-xs font-bold uppercase tracking-widest"
              />
            </div>
          )
        }
      </div>

      {
        readCount > 0 && (
          <div class="flex max-w-sm flex-col gap-1.5">
            <div class="flex justify-between text-xs text-slate-600">
              <span class="uppercase tracking-widest">Read</span>
              <span class="font-semibold text-amber-500">
                {readCount} / {total}
              </span>
            </div>
            <div class="h-1 w-full overflow-hidden bg-slate-800">
              <div class="h-full bg-amber-500" style={`width: ${readPct}%`} />
            </div>
          </div>
        )
      }
    </div>
  </div>
  <!-- Elastic: full issue grid with reading state -->
  {
    issues.length > 0 && (
      <CoverGrid>
        {issues.map((issue) => (
          <CoverLeaf
            type="Issue"
            id={issue.issue_id}
            cover={issue.issue_cover_url}
            number={issue.issue_number}
            issueName={issue.issue_name}
            issueDate={issue.issue_date?.slice(0, 7)}
            badge={
              issue.reading_state === "read"
                ? "read"
                : issue.reading_state === "reading"
                  ? "reading"
                  : issue.download_status !== "Downloaded"
                    ? "wanted"
                    : undefined
            }
            progress={
              issue.current_page && issue.issue_page_count
                ? Math.round(
                    (issue.current_page / issue.issue_page_count) * 100,
                  )
                : undefined
            }
            thumbHash={issue.issue_cover_thumb_hash}
          />
        ))}
      </CoverGrid>
    )
  }

  <!-- ComicVine fallback: same issue grid with real covers -->
  {
    cvVolume && cvPageIssues && cvPageIssues.length > 0 && (
      <CoverGrid>
        {cvPageIssues.map((issue) => (
          <CoverLeaf
            type="Issue"
            id={String(issue.id)}
            cover={issue.image?.medium_url}
            number={issue.issue_number}
            issueName={issue.name}
            issueDate={issue.cover_date?.slice(0, 7)}
          />
        ))}
      </CoverGrid>
    )
  }

  {
    issues.length > 0 && (
      <PageNavigator numberOfPages={totalPages} currentPage={currentPage} />
    )
  }
  {
    cvVolume && cvTotalPages > 1 && (
      <PageNavigator numberOfPages={cvTotalPages} currentPage={currentPage} />
    )
  }
</Layout>

<script>
  const btn = document.getElementById(
    "add-to-library-btn",
  ) as HTMLButtonElement | null;
  const status = document.getElementById("add-to-library-status");

  btn?.addEventListener("click", async () => {
    const seriesId = btn.dataset.seriesId;
    btn.disabled = true;
    btn.textContent = "Adding…";

    try {
      const res = await fetch("/api/library/add", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ seriesId }),
      });

      if (res.ok) {
        btn.classList.add("hidden");
        if (status) {
          status.textContent = "Added to library";
          status.classList.remove("hidden");
          status.classList.add("text-amber-500");
        }
      } else {
        btn.disabled = false;
        btn.innerHTML = `<img src="/icons/add.svg" class="h-4 w-4" style="display:inline;filter:invert(1)" alt=""> Add to library`;
        if (status) {
          status.textContent = "Failed — try again";
          status.classList.remove("hidden");
          status.classList.add("text-red-400");
        }
      }
    } catch {
      btn.disabled = false;
      btn.innerHTML = `<img src="/icons/add.svg" class="h-4 w-4" style="display:inline;filter:invert(1)" alt=""> Add to library`;
    }
  });
</script>
