---
import Layout from "@layouts/Layout.astro";
import {
  getContinueReading,
  getRecentlyAdded,
  getAllSeries,
} from "@data/elastic/queries";
import { Image } from "astro:assets";
import CoverLeaf from "@components/CoverLeaf/CoverLeaf.astro";
import Icon from "@components/Icon/Icon.astro";
import EyebrowLabel from "@components/EyebrowLabel.astro";
import { thumbHashToBase64 } from "@util/thumbHashToBase64";

const [continueReading, recentlyAdded, seriesResult] = await Promise.all([
  getContinueReading(5),
  getRecentlyAdded(6),
  getAllSeries(1, 6),
]);
const browseSeriesItems = seriesResult.items;

const heroSlides = await Promise.all(
  continueReading.map(async (issue) => {
    const progress =
      issue.current_page && issue.issue_page_count
        ? Math.round((issue.current_page / issue.issue_page_count) * 100)
        : null;
    const placeholderUrl = issue.issue_cover_thumb_hash
      ? await thumbHashToBase64(issue.issue_cover_thumb_hash)
      : undefined;
    return { issue, progress, placeholderUrl };
  }),
);
---

<Layout title="Comics">
  <!-- Hero Carousel -->
  {
    heroSlides.length > 0 && (
      <div
        class="hero-carousel relative -mx-4 -mt-4 mb-16"
        data-hero-carousel
        data-slide-count={heroSlides.length}
      >
        <div
          class="hero-track flex snap-x snap-mandatory overflow-x-auto scroll-smooth"
          data-hero-track
        >
          {heroSlides.map(({ issue, progress, placeholderUrl }, index) => (
            <div
              class="hero-slide relative w-full flex-none snap-start overflow-hidden"
              data-hero-slide
              data-slide-index={index}
            >
              {placeholderUrl && (
                <div
                  class="pointer-events-none absolute inset-0 z-0 opacity-30 blur-2xl scale-110"
                  style={`background-image: url(${placeholderUrl}); background-size: cover; background-position: center;`}
                />
              )}
              <div class="relative z-10 flex min-h-[520px] flex-col gap-8 px-4 py-12 md:px-8">
                {/* Title block — full-width, left-aligned, above the columns */}
                <div class="flex flex-col items-start gap-4 text-left">
                  <EyebrowLabel>Now Reading</EyebrowLabel>
                  <h1 class="text-5xl font-black leading-[0.95] tracking-tight text-white md:text-7xl">
                    {issue.series_name}
                    <span class="text-2xl text-slate-500">
                      #{issue.issue_number}
                    </span>
                  </h1>
                </div>

                <div class="grid grid-cols-1 items-center gap-8 sm:grid-cols-2">
                  {/* Cover image — first on mobile, left column on sm+ */}
                  <div
                    class="relative mx-auto h-[340px] w-[220px] overflow-hidden rounded-sm shadow-2xl ring-1 ring-white/10 sm:ml-auto sm:mr-8"
                    style={
                      placeholderUrl
                        ? `background-image: url(${placeholderUrl}); background-size: cover; background-position: center;`
                        : undefined
                    }
                  >
                    {issue.issue_cover_url && (
                      <Image
                        src={new URL(
                          issue.issue_cover_url,
                          Astro.url,
                        ).toString()}
                        alt={`Cover for ${issue.series_name} #${issue.issue_number}`}
                        widths={[183, 275, 366]}
                        sizes="(max-width: 640px) 183px, 210px"
                        width={210}
                        height={320}
                        quality="mid"
                        format="avif"
                        loading={index === 0 ? "eager" : "lazy"}
                        class="h-full w-full object-cover"
                      />
                    )}
                  </div>

                  {/* Description, button, progress */}
                  <div class="flex flex-col items-center gap-6 text-center sm:items-start sm:text-left">
                    {issue.issue_description && (
                      <div
                        set:html={issue.issue_description}
                        class="max-w-sm text-sm leading-relaxed text-slate-400 line-clamp-3"
                      />
                    )}
                    <div class="flex items-center gap-4">
                      <a
                        href={`/comic/${issue.issue_id}`}
                        class="group flex items-center gap-2 bg-amber-500 px-6 py-3 text-sm font-bold uppercase tracking-widest text-slate-900 transition-all hover:bg-amber-400"
                      >
                        Continue Reading
                        <Icon
                          name="arrow-forward"
                          class="h-4 w-4 transition-transform group-hover:translate-x-1"
                          color="currentColor"
                        />
                      </a>
                    </div>
                    {progress !== null && (
                      <div class="flex w-full max-w-sm flex-col gap-1.5">
                        <div class="flex justify-between text-xs text-slate-600">
                          <span class="uppercase tracking-widest">
                            Progress
                          </span>
                          <span class="text-amber-500 font-semibold">
                            {progress}%
                          </span>
                        </div>
                        <div class="h-1 w-full overflow-hidden bg-slate-800">
                          <div
                            class="h-full bg-amber-500"
                            style={`width: ${progress}%`}
                          />
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              </div>
              <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-slate-900 to-transparent" />
            </div>
          ))}
        </div>

        {heroSlides.length > 1 && (
          <>
            <button
              type="button"
              class="hero-nav absolute left-2 top-1/2 z-20 hidden h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-slate-950/60 text-white backdrop-blur transition-colors hover:bg-slate-950/80 md:flex"
              aria-label="Previous slide"
              data-hero-prev
            >
              <Icon name="arrow-back" class="h-5 w-5" color="currentColor" />
            </button>
            <button
              type="button"
              class="hero-nav absolute right-2 top-1/2 z-20 hidden h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-slate-950/60 text-white backdrop-blur transition-colors hover:bg-slate-950/80 md:flex"
              aria-label="Next slide"
              data-hero-next
            >
              <Icon name="arrow-forward" class="h-5 w-5" color="currentColor" />
            </button>
            <div
              class="absolute bottom-4 left-1/2 z-20 flex -translate-x-1/2 gap-2"
              data-hero-dots
            >
              {heroSlides.map((_, index) => (
                <button
                  type="button"
                  class="hero-dot h-1.5 w-6 bg-white/30 transition-all hover:bg-white/60"
                  data-hero-dot
                  data-slide-target={index}
                  aria-label={`Go to slide ${index + 1}`}
                />
              ))}
            </div>
          </>
        )}
      </div>
    )
  }

  <!-- Recently Added -->
  {
    recentlyAdded.length > 0 && (
      <section class="mb-16">
        <div class="mb-6">
          <EyebrowLabel class="mb-1">Fresh in your collection</EyebrowLabel>
          <div class="flex items-baseline justify-between">
            <h2 class="text-2xl tracking-tight text-white">Recently Added</h2>
            <a
              href="/new"
              class="inline-flex shrink-0 items-center whitespace-nowrap py-3 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-amber-500 transition-colors"
            >
              View all →
            </a>
          </div>
        </div>
        <ol class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {recentlyAdded.map((series) => (
            <CoverLeaf
              type="series"
              id={series.series_id}
              cover={series.series_cover_url}
              name={series.series_name}
              year={series.series_year}
              badge="new"
              thumbHash={series.series_cover_thumb_hash}
            />
          ))}
        </ol>
      </section>
    )
  }

  <!-- Browse Series -->
  {
    browseSeriesItems.length > 0 && (
      <section class="mb-12">
        <div class="mb-6">
          <EyebrowLabel class="mb-1">Your library</EyebrowLabel>
          <div class="flex items-baseline justify-between">
            <h2 class="text-2xl tracking-tight text-white">Browse Series</h2>
            <a
              href="/series"
              class="inline-flex shrink-0 items-center whitespace-nowrap py-3 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-amber-500 transition-colors"
            >
              All series →
            </a>
          </div>
        </div>
        <ol class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {browseSeriesItems.map((series) => (
            <CoverLeaf
              type="series"
              id={series.series_id}
              cover={series.series_cover_url}
              name={series.series_name}
              year={series.series_year}
              thumbHash={series.series_cover_thumb_hash}
            />
          ))}
        </ol>
      </section>
    )
  }
</Layout>

<style>
  .hero-track {
    scrollbar-width: none;
  }
  .hero-track::-webkit-scrollbar {
    display: none;
  }
  .hero-dot[aria-current="true"] {
    background-color: rgb(245 158 11); /* amber-500 */
  }
</style>

<script>
  function initHeroCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>("[data-hero-track]");
    const slides = Array.from(
      root.querySelectorAll<HTMLElement>("[data-hero-slide]"),
    );
    const dots = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-hero-dot]"),
    );
    const prev = root.querySelector<HTMLButtonElement>("[data-hero-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-hero-next]");
    if (!track || slides.length === 0) return;

    let current = 0;
    const setActive = (index: number) => {
      current = index;
      dots.forEach((dot, i) => {
        if (i === index) {
          dot.setAttribute("aria-current", "true");
        } else {
          dot.removeAttribute("aria-current");
        }
      });
    };
    setActive(0);

    const scrollToSlide = (index: number) => {
      const slide = slides[index];
      if (!slide) return;
      track.scrollTo({ left: slide.offsetLeft, behavior: "smooth" });
    };

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const target = Number(dot.dataset.slideTarget ?? "0");
        scrollToSlide(target);
      });
    });

    prev?.addEventListener("click", () => {
      scrollToSlide((current - 1 + slides.length) % slides.length);
    });
    next?.addEventListener("click", () => {
      scrollToSlide((current + 1) % slides.length);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
            const target = entry.target as HTMLElement;
            const index = Number(target.dataset.slideIndex ?? "0");
            setActive(index);
          }
        });
      },
      { root: track, threshold: [0.5, 0.75] },
    );
    slides.forEach((slide) => observer.observe(slide));
  }

  document
    .querySelectorAll<HTMLElement>("[data-hero-carousel]")
    .forEach(initHeroCarousel);
</script>
