---
import Layout from "@layouts/Layout.astro";
import {
  getNowReading,
  getContinueReading,
  getRecentlyAdded,
  getAllSeries,
} from "@data/elastic/queries";
import { Image } from "astro:assets";
import CoverLeaf from "@components/CoverLeaf/CoverLeaf.astro";
import Icon from "@components/Icon/Icon.astro";

const [nowReading, continueReading, recentlyAdded, seriesResult] =
  await Promise.all([
    getNowReading(),
    getContinueReading(5),
    getRecentlyAdded(6),
    getAllSeries(1, 6),
  ]);

const browseSeriesItems = seriesResult.items;

const heroProgress =
  nowReading?.current_page && nowReading?.issue_page_count
    ? Math.round((nowReading.current_page / nowReading.issue_page_count) * 100)
    : null;
---

<Layout title="Comics">
  <!-- Search overlay -->
  <div
    id="search-overlay"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm"
  >
    <div class="w-full max-w-2xl px-4">
      <div class="relative">
        <input
          type="text"
          placeholder="Search series, issues, characters…"
          class="w-full rounded-none border-b-2 border-amber-500 bg-transparent px-4 py-4 text-xl text-white placeholder-slate-500 outline-none"
          autofocus
        />
        <button
          id="close-search"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-white text-2xl"
          >&times;</button
        >
      </div>
      <p class="mt-4 text-xs text-slate-600 uppercase tracking-widest">
        Press ESC to close
      </p>
    </div>
  </div>

  <!-- Hero Section -->
  {
    nowReading && (
      <div class="relative -mx-4 -mt-4 mb-16 overflow-hidden">
        <div
          class="pointer-events-none absolute inset-0 z-10 opacity-[0.03]"
          style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22300%22 height=%22300%22 filter=%22url(%23n)%22 opacity=%221%22/></svg>'); background-repeat: repeat;"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950" />
        <div class="absolute -right-32 top-0 h-[500px] w-[500px] rounded-full bg-amber-500/10 blur-[120px]" />
        <div class="absolute -left-16 bottom-0 h-[300px] w-[300px] rounded-full bg-amber-600/5 blur-[80px]" />

        <div class="relative z-10 grid min-h-[520px] grid-cols-1 items-center gap-8 px-4 py-12 md:grid-cols-2 md:px-8">
          <div class="flex flex-col gap-6">
            <div class="flex items-center gap-3">
              <span class="h-px w-12 bg-amber-500" />
              <span class="text-xs font-bold uppercase tracking-[0.3em] text-amber-500">
                Now Reading
              </span>
            </div>
            <h1 class="text-5xl font-black leading-[0.95] tracking-tight text-white md:text-7xl">
              {nowReading.series_name}
            </h1>
            {nowReading.issue_description && (
              <p class="max-w-sm text-sm leading-relaxed text-slate-400 line-clamp-3">
                {nowReading.issue_description}
              </p>
            )}
            <div class="flex items-center gap-4">
              <a
                href={`/comic/${nowReading.issue_id}`}
                class="group flex items-center gap-2 bg-amber-500 px-6 py-3 text-sm font-bold uppercase tracking-widest text-slate-900 transition-all hover:bg-amber-400"
              >
                Continue Reading
                <Icon name="arrow-forward" class="h-4 w-4 transition-transform group-hover:translate-x-1" color="currentColor" />
              </a>
              <span class="text-sm text-slate-500">
                Issue #{nowReading.issue_number}
              </span>
            </div>
            {heroProgress !== null && (
              <div class="flex flex-col gap-1.5">
                <div class="flex justify-between text-xs text-slate-600">
                  <span class="uppercase tracking-widest">Progress</span>
                  <span class="text-amber-500 font-semibold">
                    {heroProgress}%
                  </span>
                </div>
                <div class="h-1 w-full overflow-hidden bg-slate-800">
                  <div
                    class="h-full bg-amber-500"
                    style={`width: ${heroProgress}%`}
                  />
                </div>
              </div>
            )}
          </div>

          <div class="flex items-center justify-center md:justify-end md:pr-8">
            <div class="relative h-[340px] w-[220px]">
              <div class="absolute left-8 top-4 h-[320px] w-[210px] rotate-6 rounded-sm bg-slate-700 opacity-50 shadow-xl" />
              <div class="absolute left-4 top-2 h-[320px] w-[210px] rotate-3 rounded-sm bg-slate-600 opacity-60 shadow-xl" />
              <div class="absolute inset-0 overflow-hidden rounded-sm shadow-2xl ring-1 ring-white/10">
                <Image
                  src={new URL(
                    nowReading.issue_cover_url!,
                    Astro.url,
                  ).toString()}
                  alt={`Cover for ${nowReading.series_name} #${nowReading.issue_number}`}
                  widths={[183, 275, 366]}
                  sizes="(max-width: 640px) 183px, 210px"
                  width={210}
                  height={320}
                  quality="mid"
                  format="avif"
                  class="h-full w-full object-cover"
                />
                <div class="absolute bottom-0 left-0 right-0 bg-slate-950/80 px-3 py-2 backdrop-blur-sm">
                  <p class="text-[10px] font-bold uppercase tracking-widest text-amber-500">
                    Issue #{nowReading.issue_number}
                  </p>
                </div>
              </div>
              <div class="absolute -right-1 inset-y-0 w-1 bg-amber-500 opacity-80" />
            </div>
          </div>
        </div>

        <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-slate-900 to-transparent" />
      </div>
    )
  }

  <!-- Continue Reading -->
  {
    continueReading.length > 0 && (
      <section class="mb-16">
        <div class="mb-6 flex items-end justify-between">
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-[0.3em] text-amber-500">
              Pick up where you left off
            </p>
            <h2 class="text-2xl font-black tracking-tight text-white">
              Continue Reading
            </h2>
          </div>
          <a
            href="/series"
            class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-amber-500 transition-colors"
          >
            View all →
          </a>
        </div>
        <ol class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
          {continueReading.map((issue) => (
            <CoverLeaf
              type="Issue"
              id={issue.issue_id}
              cover={issue.issue_cover_url}
              number={issue.issue_number}
              seriesName={issue.series_name}
              seriesId={issue.series_id}
              progress={
                issue.current_page && issue.issue_page_count
                  ? Math.round(
                      (issue.current_page / issue.issue_page_count) * 100,
                    )
                  : undefined
              }
              thumbHash={issue.issue_cover_thumb_hash}
            />
          ))}
        </ol>
      </section>
    )
  }

  <!-- Recently Added -->
  {
    recentlyAdded.length > 0 && (
      <section class="mb-16">
        <div class="mb-6 flex items-end justify-between">
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-[0.3em] text-amber-500">
              Fresh in your collection
            </p>
            <h2 class="text-2xl font-black tracking-tight text-white">
              Recently Added
            </h2>
          </div>
          <a
            href="/new"
            class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-amber-500 transition-colors"
          >
            View all →
          </a>
        </div>
        <ol class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {recentlyAdded.map((series) => (
            <CoverLeaf
              type="series"
              id={series.series_id}
              cover={series.series_cover_url}
              name={series.series_name}
              year={series.series_year}
              badge="new"
              thumbHash={series.series_cover_thumb_hash}
            />
          ))}
        </ol>
      </section>
    )
  }

  <!-- Browse Series -->
  {
    browseSeriesItems.length > 0 && (
      <section class="mb-12">
        <div class="mb-6 flex items-end justify-between">
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-[0.3em] text-amber-500">
              Your library
            </p>
            <h2 class="text-2xl font-black tracking-tight text-white">
              Browse Series
            </h2>
          </div>
          <a
            href="/series"
            class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-amber-500 transition-colors"
          >
            All series →
          </a>
        </div>
        <ol class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {browseSeriesItems.map((series) => (
            <CoverLeaf
              type="series"
              id={series.series_id}
              cover={series.series_cover_url}
              name={series.series_name}
              year={series.series_year}
              thumbHash={series.series_cover_thumb_hash}
            />
          ))}
        </ol>
      </section>
    )
  }
</Layout>

<script>
  const overlay = document.getElementById("search-overlay");
  const closeBtn = document.getElementById("close-search");

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      overlay?.classList.toggle("hidden");
      overlay?.classList.toggle("flex");
    }
    if (e.key === "Escape") {
      overlay?.classList.add("hidden");
      overlay?.classList.remove("flex");
    }
  });

  closeBtn?.addEventListener("click", () => {
    overlay?.classList.add("hidden");
    overlay?.classList.remove("flex");
  });
</script>
