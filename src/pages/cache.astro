---
import Layout from "@layouts/Layout.astro";
import EyebrowLabel from "@components/EyebrowLabel.astro";
import PageHeading from "@components/PageHeading.astro";
import { ComicCacheManager } from "@components/ComicCache/ComicCacheManager";
---

<Layout title="Cached comics">
  <div class="mb-8 border-b border-slate-800 pb-6">
    <EyebrowLabel class="mb-1">Offline reading</EyebrowLabel>
    <PageHeading>Cached Comics</PageHeading>
  </div>

  <ComicCacheManager client:only="preact" />
</Layout>
