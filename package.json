{
	"name": "comics",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": "24.16.0"
	},
	"scripts": {
		"dev": "astro dev --host",
		"start": "astro dev",
		"start:prod": "node ./dist/server/entry.mjs",
		"type:check": "astro check",
		"type:check:tsc": "tsc --noEmit",
		"build": "astro build && npx esbuild src/data/sync/sync-mylar-to-elastic.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/sync/sync-mylar-to-elastic.mjs",
		"sync": "node --env-file=.env.local --import tsx/esm src/data/sync/sync-mylar-to-elastic.ts",
		"preview": "npx wrangler pages dev ./dist",
		"test": "vitest run",
		"astro": "astro",
		"lint": "biome check"
	},
	"dependencies": {
		"@astrojs/node": "10.1.4",
		"@astrojs/preact": "5.1.5",
		"@atproto/jwk-jose": "^0.2.0",
		"@atproto/oauth-client-node": "^0.4.0",
		"@elastic/elasticsearch": "8.19.1",
		"@nanostores/persistent": "1.3.4",
		"@nanostores/preact": "1.1.0",
		"@preact/signals": "^2.9.0",
		"@tailwindcss/vite": "4.3.0",
		"astro": "6.4.6",
		"fflate": "^0.8.2",
		"nanostores": "1.3.0",
		"preact": "10.29.2",
		"sharp": "^0.34.5",
		"tailwindcss": "4.3.0",
		"thumbhash": "^0.1.1"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@biomejs/biome": "2.4.15",
		"@vitest/browser-playwright": "4.1.7",
		"esbuild": "0.28.0",
		"playwright": "1.60.0",
		"tsx": "4.22.3",
		"typescript": "6.0.3",
		"vitest": "4.1.7",
		"vitest-browser-preact": "1.0.0"
	}
}
